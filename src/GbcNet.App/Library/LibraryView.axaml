<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:converters="using:Avalonia.Data.Converters"
  x:Class="GbcNet.App.Library.LibraryView"
>
  <UserControl.Styles>
    <Style Selector="TextBox.library-search">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="Background" Value="{DynamicResource ChromeSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeHairBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource ChromeCornerRadius}" />
      <Setter Property="Foreground" Value="{DynamicResource ChromeTextBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox.library-search:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeFocusBorderBrush}" />
    </Style>
    <Style Selector="TextBlock.section-label">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource ChromeStatusBrush}" />
    </Style>
    <Style Selector="PathIcon.section-icon">
      <Setter Property="Width" Value="12" />
      <Setter Property="Height" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource ChromeStatusBrush}" />
    </Style>
    <Style Selector="RadioButton.library-filter-row">
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource ChromeCornerRadius}" />
      <Setter Property="Foreground" Value="{DynamicResource ChromeMutedBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{TemplateBinding CornerRadius}"
            Padding="{TemplateBinding Padding}"
          >
            <ContentPresenter
              Content="{TemplateBinding Content}"
              ContentTemplate="{TemplateBinding ContentTemplate}"
              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
            />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="RadioButton.library-filter-row:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChromeSurfaceBrush}" />
    </Style>
    <Style Selector="RadioButton.library-filter-row:focus-visible">
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeFocusBorderBrush}" />
    </Style>
    <Style Selector="RadioButton.library-filter-row:checked">
      <Setter Property="Background" Value="{DynamicResource ChromeRaisedBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChromeTextBrush}" />
    </Style>
    <Style Selector="Button.library-tile">
      <Setter Property="Width" Value="172" />
      <Setter Property="Height" Value="244" />
      <Setter Property="Margin" Value="4" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.library-tile:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChromePanelBrush}" />
    </Style>
    <Style Selector="Button.library-tile:pressed">
      <Setter Property="Background" Value="{DynamicResource ChromeSurfaceBrush}" />
    </Style>
    <Style Selector="Border.tile-badge">
      <Setter Property="Height" Value="22" />
      <Setter Property="MinWidth" Value="22" />
      <Setter Property="Padding" Value="5,0" />
      <Setter Property="CornerRadius" Value="7" />
    </Style>
    <Style Selector="Button.tile-actions">
      <Setter Property="Width" Value="22" />
      <Setter Property="Height" Value="22" />
      <Setter Property="MinWidth" Value="22" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeHairBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Foreground" Value="{DynamicResource ChromeMutedBrush}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{TemplateBinding CornerRadius}"
          >
            <ContentPresenter
              Content="{TemplateBinding Content}"
              ContentTemplate="{TemplateBinding ContentTemplate}"
              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
            />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.tile-actions:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChromeHoverBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChromeTextBrush}" />
    </Style>
    <Style Selector="Button.tile-actions:focus-visible">
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeFocusBorderBrush}" />
    </Style>
  </UserControl.Styles>

  <Border
    x:Name="LibraryPageBackground"
    Padding="24,20"
    Background="{DynamicResource ChromeBackgroundBrush}"
  >
    <Grid x:Name="LibraryPageRoot">
      <Grid
        MaxWidth="1440"
        Width="{Binding Bounds.Width, ElementName=LibraryPageRoot}"
        HorizontalAlignment="Center"
        ColumnDefinitions="176,1,*"
      >
        <StackPanel Grid.Column="0" Margin="0,0,12,0" Spacing="16">
          <TextBox
            x:Name="LibrarySearchTextBox"
            Classes="library-search"
            PlaceholderText="Search library"
          />

          <StackPanel Spacing="4">
            <StackPanel Margin="10,0,0,4" Spacing="6" Orientation="Horizontal">
              <PathIcon Classes="section-icon" Data="{StaticResource IconCardtridge}" />
              <TextBlock Classes="section-label" Text="HARDWARE" VerticalAlignment="Center" />
            </StackPanel>
            <RadioButton
              x:Name="HardwareAllFilter"
              Classes="library-filter-row"
              GroupName="HardwareFilter"
              Content="Any"
              Tag="All"
              IsChecked="True"
              Click="OnHardwareFilterChanged"
            />
            <RadioButton
              Classes="library-filter-row"
              GroupName="HardwareFilter"
              Content="Game Boy"
              Tag="Gb"
              Click="OnHardwareFilterChanged"
            />
            <RadioButton
              Classes="library-filter-row"
              GroupName="HardwareFilter"
              Content="Game Boy Color"
              Tag="Gbc"
              Click="OnHardwareFilterChanged"
            />
            <RadioButton
              Classes="library-filter-row"
              GroupName="HardwareFilter"
              Content="Super Game Boy"
              Tag="Sgb"
              Click="OnHardwareFilterChanged"
            />
          </StackPanel>

          <StackPanel Spacing="4">
            <StackPanel Margin="10,0,0,4" Spacing="6" Orientation="Horizontal">
              <PathIcon Classes="section-icon" Data="{StaticResource IconCover}" />
              <TextBlock Classes="section-label" Text="COVER" VerticalAlignment="Center" />
            </StackPanel>
            <RadioButton
              x:Name="CoverAllFilter"
              Classes="library-filter-row"
              GroupName="CoverFilter"
              Content="Any"
              Tag="All"
              IsChecked="True"
              Click="OnCoverFilterChanged"
            />
            <RadioButton
              Classes="library-filter-row"
              GroupName="CoverFilter"
              Content="With cover"
              Tag="WithCover"
              Click="OnCoverFilterChanged"
            />
            <RadioButton
              Classes="library-filter-row"
              GroupName="CoverFilter"
              Content="Missing cover"
              Tag="MissingCover"
              Click="OnCoverFilterChanged"
            />
          </StackPanel>

          <StackPanel Spacing="4">
            <StackPanel Margin="10,0,0,4" Spacing="6" Orientation="Horizontal">
              <PathIcon Classes="section-icon" Data="{StaticResource IconSort}" />
              <TextBlock Classes="section-label" Text="SORT BY" VerticalAlignment="Center" />
            </StackPanel>
            <RadioButton
              x:Name="SortRecentFilter"
              Classes="library-filter-row"
              GroupName="SortMode"
              Content="Recently played"
              Tag="LastOpened"
              IsChecked="True"
              Click="OnSortModeChanged"
            />
            <RadioButton
              Classes="library-filter-row"
              GroupName="SortMode"
              Content="Title"
              Tag="Title"
              Click="OnSortModeChanged"
            />
            <RadioButton
              Classes="library-filter-row"
              GroupName="SortMode"
              Content="Most played"
              Tag="MostPlayed"
              Click="OnSortModeChanged"
            />
            <RadioButton
              Classes="library-filter-row"
              GroupName="SortMode"
              Content="Recently added"
              Tag="RecentlyAdded"
              Click="OnSortModeChanged"
            />
          </StackPanel>
        </StackPanel>

        <Border Grid.Column="1" Background="{DynamicResource ChromeHairBrush}" />

        <Grid Grid.Column="2" RowDefinitions="Auto,*">
          <Border
            Grid.Row="0"
            Padding="22,0,20,14"
            BorderBrush="{DynamicResource ChromeHairBrush}"
            BorderThickness="0,0,0,1"
          >
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock
                Text="Library"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="{DynamicResource ChromeTextBrush}"
                VerticalAlignment="Center"
              />
              <TextBlock
                x:Name="LibraryCountText"
                Grid.Column="1"
                Text="0 ROMs"
                FontSize="12"
                Foreground="{DynamicResource ChromeMutedBrush}"
                VerticalAlignment="Center"
              />
            </Grid>
          </Border>

          <Grid Grid.Row="1">
            <ScrollViewer
              x:Name="LibraryScrollViewer"
              Padding="10,14,10,0"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
            >
              <Grid RowDefinitions="Auto,32">
                <ItemsControl x:Name="RomTilesControl">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                      <Button Classes="library-tile" Click="OnRomTileClick">
                        <Grid RowDefinitions="156,44,28">
                          <Border
                            Grid.Row="0"
                            Width="156"
                            Height="156"
                            Background="{DynamicResource ChromeSurfaceBrush}"
                            ClipToBounds="True"
                            CornerRadius="{DynamicResource ChromeCornerRadius}"
                          >
                            <Grid>
                              <Image
                                Source="{Binding CoverBitmap}"
                                IsVisible="{Binding CoverBitmap, Converter={x:Static converters:ObjectConverters.IsNotNull}}"
                                Stretch="Fill"
                              />
                              <TextBlock
                                Text="ROM"
                                IsVisible="{Binding CoverBitmap, Converter={x:Static converters:ObjectConverters.IsNull}}"
                                Foreground="{DynamicResource ChromeMutedBrush}"
                                FontSize="26"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                              />
                            </Grid>
                          </Border>

                          <TextBlock
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            Text="{Binding Title}"
                            Foreground="{DynamicResource ChromeTextBrush}"
                            FontSize="13"
                            FontWeight="Medium"
                            MaxLines="2"
                            TextTrimming="WordEllipsis"
                            TextWrapping="Wrap"
                            VerticalAlignment="Top"
                          />

                          <Grid Grid.Row="2" ColumnDefinitions="*,Auto,28" ColumnSpacing="8">
                            <TextBlock
                              Text="{Binding PlayCountText}"
                              Foreground="{DynamicResource ChromeMutedBrush}"
                              FontSize="11"
                              TextTrimming="CharacterEllipsis"
                              VerticalAlignment="Center"
                            />
                            <Border
                              Grid.Column="1"
                              Classes="badge tile-badge"
                              HorizontalAlignment="Right"
                            >
                              <TextBlock
                                Text="{Binding HardwareText}"
                                Classes="badge-text"
                                VerticalAlignment="Center"
                              />
                            </Border>
                            <Button
                              Grid.Column="2"
                              Classes="tile-actions"
                              Loaded="OnTileActionsButtonLoaded"
                              Click="OnTileActionsButtonClick"
                              AutomationProperties.Name="ROM actions"
                            >
                              <PathIcon
                                Width="12"
                                Height="12"
                                Data="{StaticResource IconSettings}"
                              />
                            </Button>
                          </Grid>
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Grid.Row="1" />
              </Grid>
            </ScrollViewer>

            <Grid x:Name="EmptyState">
              <StackPanel
                MaxWidth="320"
                Spacing="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
              >
                <TextBlock
                  x:Name="EmptyStateText"
                  Text="No ROMs yet"
                  FontSize="16"
                  FontWeight="SemiBold"
                  Foreground="{DynamicResource ChromeTextBrush}"
                  TextAlignment="Center"
                />
                <TextBlock
                  x:Name="EmptyStateDescription"
                  Text="Open a ROM to add it to your library."
                  FontSize="12"
                  Foreground="{DynamicResource ChromeMutedBrush}"
                  TextAlignment="Center"
                  TextWrapping="Wrap"
                />
                <Button
                  x:Name="ClearFiltersButton"
                  Classes="chrome-button"
                  Margin="0,4,0,0"
                  Content="Clear filters"
                  Click="ClearFilters"
                  HorizontalAlignment="Center"
                />
              </StackPanel>
            </Grid>
          </Grid>
        </Grid>
      </Grid>
    </Grid>
  </Border>
</UserControl>
