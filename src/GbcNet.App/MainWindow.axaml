<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:menus="clr-namespace:GbcNet.App.Menus"
  x:Class="GbcNet.App.MainWindow"
  Title="GbcNet"
  Width="960"
  Height="576"
  MinWidth="640"
  MinHeight="576"
  WindowStartupLocation="CenterScreen"
  Background="#101010"
>
  <Grid RowDefinitions="Auto,*,Auto">
    <menus:MainMenu x:Name="MainMenu" Grid.Row="0" />

    <ContentControl x:Name="ContentHost" Grid.Row="1" />

    <Border
      x:Name="StatusBar"
      Grid.Row="2"
      Background="#050505"
      BorderBrush="#141414"
      BorderThickness="0,1,0,0"
      Padding="14,6"
    >
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <TextBlock
          x:Name="StatusTextBlock"
          Foreground="#71717a"
          FontSize="12"
          TextTrimming="CharacterEllipsis"
        />
        <TextBlock
          x:Name="StatusMetricsTextBlock"
          Grid.Column="1"
          Foreground="#5f5f66"
          FontSize="12"
          TextTrimming="CharacterEllipsis"
        />
      </Grid>
    </Border>
  </Grid>
</Window>
