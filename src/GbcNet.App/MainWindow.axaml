<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:menus="clr-namespace:GbcNet.App.Menus"
        x:Class="GbcNet.App.MainWindow"
        Title="GbcNet"
        Width="960"
        Height="720"
        MinWidth="640"
        MinHeight="576"
        WindowStartupLocation="CenterScreen"
        FontFamily="Inter"
        Background="#101010">
    <Grid RowDefinitions="Auto,*">
        <menus:MainMenu x:Name="MainMenu"
                        Grid.Row="0" />

        <Border Background="#050505"
                Padding="24"
                Grid.Row="1">
            <Viewbox Stretch="Uniform">
                <Border Width="160"
                        Height="144"
                        Background="#050505"
                        RenderOptions.BitmapInterpolationMode="None">
                    <Image x:Name="ScreenImage"
                           Width="160"
                           Height="144"
                           Stretch="Fill" />
                </Border>
            </Viewbox>
        </Border>
    </Grid>
</Window>
