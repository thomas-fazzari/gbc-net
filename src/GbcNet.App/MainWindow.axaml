<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:menus="clr-namespace:GbcNet.App.Menus"
  x:Class="GbcNet.App.MainWindow"
  Title="GbcNet"
  Width="960"
  Height="576"
  MinWidth="640"
  MinHeight="576"
  WindowStartupLocation="CenterScreen"
>
  <Grid RowDefinitions="Auto,*,Auto">
    <menus:MainMenu x:Name="MainMenu" Grid.Row="0" />

    <ContentControl x:Name="ContentHost" Grid.Row="1" />

    <Border x:Name="StatusBar" Grid.Row="2" BorderThickness="0,1,0,0" Padding="14,6">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
        <Border x:Name="StatusCoverFrame" Width="18" Height="18" CornerRadius="3">
          <Image x:Name="StatusCoverImage" Stretch="UniformToFill" />
        </Border>
        <TextBlock
          x:Name="StatusTextBlock"
          Grid.Column="1"
          FontSize="12"
          TextTrimming="CharacterEllipsis"
          VerticalAlignment="Center"
        />
        <TextBlock
          x:Name="StatusSpeedTextBlock"
          Grid.Column="2"
          FontSize="12"
          TextTrimming="CharacterEllipsis"
        />
      </Grid>
    </Border>
  </Grid>
</Window>
