<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Class="GbcNet.App.Emulation.EmulationView"
>
  <Border Background="#050505" Padding="24">
    <Viewbox Stretch="Uniform">
      <Border Background="#050505" RenderOptions.BitmapInterpolationMode="None">
        <Image x:Name="ScreenImage" Width="160" Height="144" Stretch="Fill" />
      </Border>
    </Viewbox>
  </Border>
</UserControl>
