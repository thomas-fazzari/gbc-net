<Application
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Class="GbcNet.App.GbcNetApplication"
  Name="GbcNet"
  RequestedThemeVariant="Dark"
>
  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="About GbcNet" />
      <NativeMenuItem Header="Preferences..." Gesture="Meta+OemComma" />
    </NativeMenu>
  </NativeMenu.Menu>

  <Application.Resources>
    <FontFamily x:Key="AppFont">
      avares://GbcNet/Assets/Fonts/HankenGrotesk.ttf#Hanken Grotesk
    </FontFamily>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="MenuItem">
      <Setter Property="Cursor" Value="Hand" />
    </Style>
  </Application.Styles>
</Application>
