<Application
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  x:Class="GbcNet.App.GbcNetApplication"
  Name="GbcNet"
  RequestedThemeVariant="Dark"
>
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://GbcNet/Shell/Chrome/Icons.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <FontFamily x:Key="AppFont">avares://GbcNet/Assets/Fonts#Cabin</FontFamily>

      <SolidColorBrush x:Key="ChromeBackgroundBrush">#0d0d0f</SolidColorBrush>
      <SolidColorBrush x:Key="ChromePanelBrush">#131316</SolidColorBrush>
      <SolidColorBrush x:Key="ChromeSurfaceBrush">#18181b</SolidColorBrush>
      <SolidColorBrush x:Key="ChromeRaisedBrush">#1e1e22</SolidColorBrush>
      <SolidColorBrush x:Key="ChromeHoverBrush">#26262b</SolidColorBrush>
      <SolidColorBrush x:Key="ChromePressedBrush">#2f2f35</SolidColorBrush>
      <SolidColorBrush x:Key="ChromeSelectedBrush">#1c1c21</SolidColorBrush>

      <SolidColorBrush x:Key="ChromeAccentBrush">#26262e</SolidColorBrush>
      <SolidColorBrush x:Key="ChromeAccentHoverBrush">#3d5a80</SolidColorBrush>
      <SolidColorBrush x:Key="ChromeAccentPressedBrush">#2f4762</SolidColorBrush>

      <SolidColorBrush x:Key="ChromeHairBrush">#14ffffff</SolidColorBrush>
      <SolidColorBrush x:Key="ChromeSelectedBorderBrush">#22ffffff</SolidColorBrush>
      <SolidColorBrush x:Key="ChromeFocusBorderBrush">#2effffff</SolidColorBrush>

      <SolidColorBrush x:Key="ChromeTextBrush">#e4e4e7</SolidColorBrush>
      <SolidColorBrush x:Key="ChromeMutedBrush">#71717a</SolidColorBrush>
      <SolidColorBrush x:Key="ChromeErrorBrush">#f87171</SolidColorBrush>
      <SolidColorBrush x:Key="ChromeStatusBrush">#8a8a93</SolidColorBrush>

      <CornerRadius x:Key="ChromeCornerRadius">2</CornerRadius>
    </ResourceDictionary>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="MenuItem">
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.chrome-button">
      <Setter Property="Height" Value="30" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{DynamicResource ChromeTextBrush}" />
      <Setter Property="Background" Value="{DynamicResource ChromeRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeHairBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource ChromeCornerRadius}" />
    </Style>
    <Style Selector="Button.chrome-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChromeHoverBrush}" />
    </Style>
    <Style Selector="Button.chrome-button:pressed">
      <Setter Property="Background" Value="{DynamicResource ChromePressedBrush}" />
    </Style>
    <Style Selector="Button.chrome-button:focus-visible">
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeFocusBorderBrush}" />
    </Style>
    <Style Selector="Border.badge">
      <Setter Property="Padding" Value="5,1" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeHairBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.badge-text">
      <Setter Property="Foreground" Value="{DynamicResource ChromeMutedBrush}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.chrome-button.accent">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChromeAccentBrush}" />
    </Style>
    <Style Selector="Button.chrome-button.accent:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentHoverBrush}" />
    </Style>
    <Style Selector="Button.chrome-button.accent:pressed">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentPressedBrush}" />
    </Style>
  </Application.Styles>
</Application>
