<Window xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         x:Class="GbcNet.Gui.MainWindow"
        Title="GbcNet"
        Width="960"
        Height="720"
        MinWidth="640"
        MinHeight="576"
        WindowStartupLocation="CenterScreen"
        Background="#101010">
    <Grid>
        <Border Background="#050505"
                Padding="24">
            <Viewbox Stretch="Uniform">
                <Border Width="160"
                        Height="144"
                        Background="#050505"
                        RenderOptions.BitmapInterpolationMode="None">
                    <Image x:Name="ScreenImage"
                           Width="160"
                           Height="144"
                           Stretch="Fill" />
                </Border>
            </Viewbox>
        </Border>
    </Grid>
</Window>
