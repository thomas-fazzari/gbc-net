<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GbcNet.Gui.App"
             Name="GbcNet"
             RequestedThemeVariant="Dark">
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="About GbcNet" />
            <NativeMenuItem Header="Preferences..." Gesture="Meta+OemComma" />
        </NativeMenu>
    </NativeMenu.Menu>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
